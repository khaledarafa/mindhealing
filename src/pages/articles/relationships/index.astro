---
import MainLayout from "../../../layouts/MainLayout.astro";
import { articles } from "../../../data/articles";

const relationshipArticles = articles.filter(article =>
  article.lang === "en" &&
  article.link.includes("/relationships/")
);
---

<MainLayout
  title="Relationships & Emotional Awareness | Mind Healing"
  description="Discover articles about relationships, emotional attachment, loneliness, self worth, emotional awareness, and modern relationship struggles."
>

<div class="container">

  <div class="category-hero">

    <h1>
      💔 Relationships & Emotional Awareness
    </h1>

    <p class="page-desc">
      Discover articles about relationships,
      emotional attachment,
      loneliness,
      emotional needs,
      fear of abandonment,
      self worth,
      and emotional awareness.
    </p>

  </div>

  <div class="search-box">

    <input
      type="text"
      id="searchInput"
      placeholder="Search relationship articles..."
    />

    <button id="clearSearch">
      ✕
    </button>

  </div>

  <div class="section">

    <div class="grid" id="articles">

      {
        relationshipArticles.map(article => (

          <div class="card">

            <h3>{article.title}</h3>

            <p>{article.desc}</p>

            <a href={article.link}>
              Read Article →
            </a>

          </div>

        ))
      }

    </div>

  </div>

</div>

<script define:vars={{ relationshipArticles }}>

const container =
  document.getElementById("articles");

const searchInput =
  document.getElementById("searchInput");

const clearBtn =
  document.getElementById("clearSearch");

function renderArticles(
  filtered = relationshipArticles
) {

  container.innerHTML =
    filtered.map(article => `

      <div class="card">

        <h3>${article.title}</h3>

        <p>${article.desc}</p>

        <a href="${article.link}">
          Read Article →
        </a>

      </div>

    `).join("");

}

searchInput.addEventListener("input", () => {

  const value =
    searchInput.value.toLowerCase();

  clearBtn.style.display =
    value ? "block" : "none";

  const filtered =
    relationshipArticles.filter(article => {

      return (

        article.title.toLowerCase().includes(value)

        ||

        article.desc.toLowerCase().includes(value)

      );

    });

  renderArticles(filtered);

});

clearBtn.addEventListener("click", () => {

  searchInput.value = "";

  clearBtn.style.display = "none";

  renderArticles();

});

</script>

</MainLayout>