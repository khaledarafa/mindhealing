---
import MainLayout from "../../../../layouts/MainLayout.astro";
import { articles } from "../../../../data/articles";

const affirmationsArticles = articles.filter(article =>
  article.lang === "ar" &&
  article.link.includes("/affirmations/")
);
---

<MainLayout
  title="التوكيدات الإيجابية | Mind Healing"
  description="اكتشف أفضل التوكيدات الإيجابية للثقة بالنفس والسلام الداخلي والطاقة الإيجابية."
>

<div class="container">

  <div class="category-hero">

    <h1>
      ✨ التوكيدات الإيجابية
    </h1>

    <p class="page-desc">
      اكتشف مجموعة من أفضل التوكيدات الإيجابية
      لتحسين العقلية والثقة بالنفس والسلام الداخلي والتحفيز اليومي.
    </p>

  </div>

  <div class="search-box">

    <input
      type="text"
      id="searchInput"
      placeholder="ابحث داخل التوكيدات..."
    />

    <button id="clearSearch">
      ✕
    </button>

  </div>

  <div class="section">

    <div class="grid" id="articles">

      {
        affirmationsArticles.map(article => (

          <div class="card">

            <h3>{article.title}</h3>

            <p>{article.desc}</p>

            <a href={article.link}>
              اقرأ المقال →
            </a>

          </div>

        ))
      }

    </div>

  </div>

</div>

<script define:vars={{ affirmationsArticles }}>

const container = document.getElementById("articles");

const searchInput = document.getElementById("searchInput");

const clearBtn = document.getElementById("clearSearch");

function renderArticles(filtered = affirmationsArticles) {

  container.innerHTML = filtered.map(article => `

    <div class="card">

      <h3>${article.title}</h3>

      <p>${article.desc}</p>

      <a href="${article.link}">
        اقرأ المقال →
      </a>

    </div>

  `).join("");

}

searchInput.addEventListener("input", () => {

  const value = searchInput.value.toLowerCase();

  clearBtn.style.display =
    value ? "block" : "none";

  const filtered = affirmationsArticles.filter(article => {

    return (

      article.title.toLowerCase().includes(value)

      ||

      article.desc.toLowerCase().includes(value)

    );

  });

  renderArticles(filtered);

});

clearBtn.addEventListener("click", () => {

  searchInput.value = "";

  clearBtn.style.display = "none";

  renderArticles();

});

</script>

</MainLayout>