---
import MainLayout from "../../../../layouts/MainLayout.astro";
import { articles } from "../../../../data/articles";

const mindsetArticles = articles.filter(article =>
  article.lang === "ar" &&
  article.link.includes("/mindset/")
);
---

<MainLayout
  title="العقلية وتطوير الذات | Mind Healing"
  description="اكتشف مقالات عن تطوير العقلية والتفكير الإيجابي والعادات الصحية والتحفيز والانضباط وبناء حياة أفضل خطوة بخطوة."
>

<div class="container">

  <div class="category-hero">

    <h1>
      🧠 العقلية وتطوير الذات
    </h1>

    <p class="page-desc">
      اكتشف مقالات عن تطوير العقلية،
      التفكير الإيجابي،
      العادات،
      التحفيز،
      الانضباط،
      وتطوير الذات.
    </p>

  </div>

  <div class="search-box">

    <input
      type="text"
      id="searchInput"
      placeholder="ابحث داخل مقالات العقلية..."
    />

    <button id="clearSearch">
      ✕
    </button>

  </div>

  <div class="section">

    <div class="grid" id="articles">

      {
        mindsetArticles.map(article => (

          <div class="card">

            <h3>{article.title}</h3>

            <p>{article.desc}</p>

            <a href={article.link}>
              اقرأ المقال →
            </a>

          </div>

        ))
      }

    </div>

  </div>

</div>

<script define:vars={{ mindsetArticles }}>

const container =
  document.getElementById("articles");

const searchInput =
  document.getElementById("searchInput");

const clearBtn =
  document.getElementById("clearSearch");

function renderArticles(
  filtered = mindsetArticles
) {

  container.innerHTML =
    filtered.map(article => `

      <div class="card">

        <h3>${article.title}</h3>

        <p>${article.desc}</p>

        <a href="${article.link}">
          اقرأ المقال →
        </a>

      </div>

    `).join("");

}

searchInput.addEventListener("input", () => {

  const value =
    searchInput.value.toLowerCase();

  clearBtn.style.display =
    value ? "block" : "none";

  const filtered =
    mindsetArticles.filter(article => {

      return (

        article.title.toLowerCase().includes(value)

        ||

        article.desc.toLowerCase().includes(value)

      );

    });

  renderArticles(filtered);

});

clearBtn.addEventListener("click", () => {

  searchInput.value = "";

  clearBtn.style.display = "none";

  renderArticles();

});

</script>

</MainLayout>