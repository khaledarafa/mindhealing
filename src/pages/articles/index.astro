---
// src/pages/articles/index.astro
import MainLayout from "../../layouts/MainLayout.astro";

import { articles } from "../../data/articles";
const englishArticles =
  articles.filter(
    article => article.lang === "en"
  );
---

<MainLayout
    title="All Articles | Mind Healing"
    description="Explore all self improvement and mindset articles."
>
    <div class="container">
        <!-- SEARCH -->

        <div class="search-box">
            <input
                type="text"
                id="searchInput"
                placeholder="Search articles..."
            />

            <button id="clearSearch"> ✕ </button>
        </div>

        <!-- HERO -->

        <div class="page-hero">
            <h1>📚 All Articles</h1>

            <p class="page-desc">
                Explore articles about self improvement, affirmations,
                confidence, inner peace, and positive mindset.
            </p>

            <div class="top-categories">
                <a href="/articles/affirmations"> ✨ Affirmations </a>

                <a href="/articles/confidence"> 💪 Confidence </a>

                <a href="/articles/mindset"> 🧠 Mindset </a>

                <a href="/articles/self-worth"> ❤️ Self Worth </a>
            </div>
        </div>

        <!-- ARTICLES -->

        <h2>All Articles</h2>

        <div class="section">
            <div class="grid" id="articles"></div>
        </div>

        <!-- PAGINATION -->

        <div class="pagination" id="pagination"></div>
    </div>
<script define:vars={{ articles: englishArticles }}>

window.addEventListener("DOMContentLoaded", () => {

    const container = document.getElementById("articles");

    const pagination = document.getElementById("pagination");

    const searchInput = document.getElementById("searchInput");

    const clearBtn = document.getElementById("clearSearch");

    const perPage = 9;

    const params = new URLSearchParams(window.location.search);

    let currentPage = parseInt(params.get("page")) || 1;

    let searchValue = params.get("search") || "";

    searchInput.value = searchValue;

    if (searchValue) {
        clearBtn.style.display = "block";
    }

    function getFilteredArticles() {

        if (!searchValue.trim()) return articles;

        return articles.filter((article) => {

            return (
                article.title.toLowerCase().includes(searchValue.toLowerCase()) ||

                article.desc.toLowerCase().includes(searchValue.toLowerCase())
            );

        });

    }

    function renderArticles() {

        const filteredArticles = getFilteredArticles();

        const start = (currentPage - 1) * perPage;

        const end = start + perPage;

        const paginatedArticles = filteredArticles.slice(start, end);

        container.innerHTML = paginatedArticles.map((article) => `

            <div class="card">

                <h3>${article.title}</h3>

                <p>${article.desc}</p>

                <a href="${article.link}">
                    Read More →
                </a>

            </div>

        `).join("");

        renderPagination(filteredArticles.length);

    }

    function renderPagination(totalItems) {

        const totalPages = Math.ceil(totalItems / perPage);

        if (searchValue) {

            pagination.style.display = "none";

            return;
        }

        pagination.style.display = "flex";

        let buttons = "";

        if (currentPage > 1) {

            buttons += `
                <a href="?page=${currentPage - 1}" class="btn">
                    ← Prev
                </a>
            `;
        }

        for (let i = 1; i <= totalPages; i++) {

            buttons += `
                <a href="?page=${i}" class="btn ${i === currentPage ? "active-page" : ""}">
                    ${i}
                </a>
            `;
        }

        if (currentPage < totalPages) {

            buttons += `
                <a href="?page=${currentPage + 1}" class="btn">
                    Next →
                </a>
            `;
        }

        pagination.innerHTML = buttons;
    }

    renderArticles();

    searchInput.addEventListener("input", () => {

        searchValue = searchInput.value.trim();

        currentPage = 1;

        clearBtn.style.display = searchValue ? "block" : "none";

        renderArticles();

    });

    searchInput.addEventListener("keydown", (e) => {

        if (e.key === "Enter") {

            e.preventDefault();

            renderArticles();

        }

    });

    clearBtn.addEventListener("click", () => {

        searchInput.value = "";

        searchValue = "";

        clearBtn.style.display = "none";

        renderArticles();

        searchInput.focus();

    });

});

</script>
