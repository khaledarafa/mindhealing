---
const isProd = import.meta.env.PROD;
---

{
  isProd && (
    <>
      <!-- Google Analytics -->

      <script
        async
        src="https://www.googletagmanager.com/gtag/js?id=G-CW5KG34CS1">
      </script>

      <script is:inline>
        {`
          window.dataLayer =
            window.dataLayer || [];

          function gtag() {
            dataLayer.push(arguments);
          }

          gtag('js', new Date());

          gtag(
            'config',
            'G-CW5KG34CS1'
          );
        `}
      </script>
    </>
  )
}