---
import MainLayout from "../../../layouts/MainLayout.astro";
import { articles } from "../../../data/articles";

const affirmationsArticles = articles.filter(article =>
  article.lang === "en" &&
  article.link.includes("/affirmations/")
);
---

<MainLayout
    title="Positive Affirmations | Mind Growth"
    description="Explore powerful positive affirmations for confidence, inner peace, self love, motivation, and emotional healing."
>

<div class="container">

    <div class="category-hero">

        <h1>
            ✨ Positive Affirmations
        </h1>

        <p class="page-desc">
            Explore powerful positive affirmations
            for confidence, mindset,
            inner peace,
            motivation,
            and emotional healing.
        </p>

    </div>

    <div class="search-box">

        <input
            type="text"
            id="searchInput"
            placeholder="Search affirmations..."
        />

        <button id="clearSearch">
            ✕
        </button>

    </div>

    <div class="section">

        <div class="grid" id="articles">

            {
                affirmationsArticles.map(article => (

                    <div class="card">

                        <h3>{article.title}</h3>

                        <p>{article.desc}</p>

                        <a href={article.link}>
                            Read More →
                        </a>

                    </div>

                ))
            }

        </div>

    </div>

</div>

<script define:vars={{ affirmationsArticles }}>

const container = document.getElementById("articles");

const searchInput = document.getElementById("searchInput");

const clearBtn = document.getElementById("clearSearch");

function renderArticles(filtered = affirmationsArticles) {

    container.innerHTML = filtered.map(article => `

        <div class="card">

            <h3>${article.title}</h3>

            <p>${article.desc}</p>

            <a href="${article.link}">
                Read More →
            </a>

        </div>

    `).join("");

}

searchInput.addEventListener("input", () => {

    const value = searchInput.value.toLowerCase();

    clearBtn.style.display =
        value ? "block" : "none";

    const filtered = affirmationsArticles.filter(article => {

        return (

            article.title.toLowerCase().includes(value)

            ||

            article.desc.toLowerCase().includes(value)

        );

    });

    renderArticles(filtered);

});

clearBtn.addEventListener("click", () => {

    searchInput.value = "";

    clearBtn.style.display = "none";

    renderArticles();

});

</script>

</MainLayout>